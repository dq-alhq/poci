generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// AUTH
//////////////////////////

model User {
  id              String    @id
  name            String
  email           String
  emailVerified   Boolean   @default(false)
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  role            String?   @default("user")
  banned          Boolean?  @default(false)
  banReason       String?
  banExpires      DateTime?
  username        String?
  displayUsername String?

  sessions       Session[]
  accounts       Account[]
  stockTransfers StockTransfer[]
  purchases      Purchase[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

//////////////////////////
// MASTER
//////////////////////////
enum TransferType {
  OUT // Ambil dari gudang ke outlet
  IN // Pembelian
  RETURN // Balikin dari outlet ke gudang
  DAMAGED // Barang rusak
}

enum TransferStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// --- Tabel-Tabel Utama ---

model Product {
  id    String  @id @default(cuid())
  name  String
  unit  String  @default("pcs")
  image String?

  isProduct Boolean @default(true)

  buyPrice  Int
  sellPrice Int

  qty Int @default(0)

  outletStocks  OutletStock[]
  transferItems TransferItem[]
  salesItems    SalesItem[]
  purchaseItems PurchaseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product")
}

model Outlet {
  id        String  @id @default(cuid())
  name      String
  location  String?
  latitude  String?
  longitude String?

  stocks       OutletStock[]
  transfers    StockTransfer[]
  shiftReports ShiftReport[]

  @@map("outlet")
}

model OutletStock {
  id  Int @id @default(autoincrement())
  qty Int @default(0)

  outletId  String
  outlet    Outlet  @relation(fields: [outletId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@unique([outletId, productId]) // Pastikan satu outlet hanya punya satu row per produk
  @@map("outlet_stock")
}

// --- Tabel Transaksi & Pergerakan ---
model StockTransfer {
  id        Int            @id @default(autoincrement())
  type      TransferType
  status    TransferStatus @default(PENDING)
  createdAt DateTime       @default(now())

  items    TransferItem[]
  outletId String
  outlet   Outlet         @relation(fields: [outletId], references: [id])

  shiftId     Int?
  shiftReport ShiftReport? @relation(fields: [shiftId], references: [id])

  note String?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@map("stock_transfer")
}

model ShiftReport {
  id     Int         @id @default(autoincrement())
  date   DateTime    @default(now())
  status ShiftStatus @default(OPEN)

  sales     SalesItem[]
  transfers StockTransfer[] // Track ambil/balikin barang dalam satu shift

  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id])

  @@map("shift_report")
}

model TransferItem {
  id         Int @id @default(autoincrement())
  transferId Int
  qty        Int

  transfer  StockTransfer @relation(fields: [transferId], references: [id])
  productId String
  product   Product       @relation(fields: [productId], references: [id])

  @@map("transfer_item")
}

model SalesItem {
  id    Int @id @default(autoincrement())
  qty   Int
  price Int

  shiftReportId Int
  shiftReport   ShiftReport @relation(fields: [shiftReportId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])

  @@map("sales_item")
}

// --- Tabel Pengadaan (Kulakan) ---

model Purchase {
  id       Int    @id @default(autoincrement())
  supplier String
  total    Int

  createdAt DateTime @default(now())

  items PurchaseItem[]

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@map("purchase")
}

model PurchaseItem {
  id         Int    @id @default(autoincrement())
  purchaseId Int
  productId  String
  qty        Int
  price      Int

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@map("purchase_item")
}
