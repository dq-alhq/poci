generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////
// AUTH
//////////////////////////

model User {
  id              String    @id
  name            String
  email           String
  emailVerified   Boolean   @default(false)
  image           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  role            String?   @default("user")
  banned          Boolean?  @default(false)
  banReason       String?
  banExpires      DateTime?
  username        String?
  displayUsername String?

  sessions       Session[]
  accounts       Account[]
  stockTransfers StockTransfer[]
  shifts         Shift[]
  purchases      Purchase[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Item {
  id    String  @id @default(cuid())
  name  String
  price Int
  stock Int     @default(0)
  unit  String  @default("pcs")
  image String?

  isMaterial Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outletStocks       OutletStock[]
  stockTransferItems StockTransferItem[]
  purchaseItems      PurchaseItem[]
  productItems       ProductItem[]

  @@map("item")
}

model Product {
  id    String  @id @default(cuid())
  name  String
  price Int
  image String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems    SaleItem[]
  productItems ProductItem[]

  @@map("product")
}

model ProductItem {
  qty Int @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  @@id([productId, itemId])
  @@map("product_item")
}

model Outlet {
  id        String  @id @default(cuid())
  name      String
  location  String?
  latitude  String?
  longitude String?

  outletStocks   OutletStock[]
  stockTransfers StockTransfer[]
  shifts         Shift[]
  sales          Sale[]

  @@map("outlet")
}

model OutletStock {
  id    String @id @default(cuid())
  stock Int    @default(0)

  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id])
  itemId   String
  item     Item   @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([outletId, itemId])
  @@map("outlet_stock")
}

enum TransferType {
  IN
  OUT
  DAMAGED
}

model StockTransfer {
  id   Int          @id @default(autoincrement())
  type TransferType @default(IN)

  outletId String?
  outlet   Outlet? @relation(fields: [outletId], references: [id])

  note String?

  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  items StockTransferItem[]

  @@map("stock_transfer")
}

model StockTransferItem {
  id  String @id @default(cuid())
  qty Int    @default(0)

  stockTransferId Int
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  @@unique([stockTransferId, itemId])
  @@map("stock_transfer_item")
}

model Shift {
  id     Int       @id @default(autoincrement())
  start  DateTime  @default(now())
  end    DateTime?
  isOpen Boolean   @default(true)

  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
  sales  Sale[]

  @@map("shift")
}

model Purchase {
  id    Int     @id @default(autoincrement())
  title String?
  total Int

  createdAt DateTime @default(now())

  items PurchaseItem[]

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@map("purchase")
}

model PurchaseItem {
  id    Int @id @default(autoincrement())
  qty   Int
  price Int

  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  @@unique([purchaseId, itemId])
  @@map("purchase_item")
}

model Sale {
  id    Int     @id @default(autoincrement())
  title String?
  total Int

  createdAt DateTime @default(now())

  items SaleItem[]

  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id])

  shiftId Int?
  shift   Shift? @relation(fields: [shiftId], references: [id])

  @@unique([outletId, shiftId])
  @@map("sale")
}

model SaleItem {
  id    Int @id @default(autoincrement())
  qty   Int
  price Int

  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@unique([saleId, productId])
  @@map("sale_item")
}
